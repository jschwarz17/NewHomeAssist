# Picovoice (Porcupine wake word + Eagle speaker ID)
# Get key: https://console.picovoice.ai/
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=

# Gemini API (Vercel backend)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Backend URL for the tablet app (Vercel deployment)
# e.g. https://jesse-home-assistant.vercel.app
NEXT_PUBLIC_ASSISTANT_API_URL=
