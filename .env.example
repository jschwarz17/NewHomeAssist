# Picovoice (Porcupine wake phrase "Hi Ara" + Eagle speaker ID)
# Get key: https://console.picovoice.ai/
NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=

# xAI Grok API (Ara's brain + Voice Agent)
# Get key: https://console.x.ai/team/default/api-keys
XAI_API_KEY=

# Optional: Grok chat model (default grok-3-mini)
# GROK_MODEL=grok-4

# Backend URL for the tablet app (Vercel deployment)
# e.g. https://jesse-home-assistant.vercel.app
NEXT_PUBLIC_ASSISTANT_API_URL=
