# Picovoice (Porcupine wake phrase "Hi Ara")
# Get key: https://console.picovoice.ai/
# Server: PICOVOICE_API_KEY. Client (browser): set NEXT_PUBLIC_PICOVOICE_API_KEY with same value.
PICOVOICE_API_KEY=
NEXT_PUBLIC_PICOVOICE_API_KEY=

# xAI Grok API (Ara's brain + Voice Agent)
# Get key: https://console.x.ai/team/default/api-keys
XAI_API_KEY=

# Optional: Grok chat model (default grok-3-mini)
# GROK_MODEL=grok-4

# Anthropic Claude API (task/agent loop)
# Get key: https://console.anthropic.com/
CLAUDE_API_KEY=

# Backend URL for the tablet app (Vercel deployment)
# e.g. https://jesse-home-assistant.vercel.app
NEXT_PUBLIC_ASSISTANT_API_URL=

# Local SQLite (learning/personalization). Not persistent on Vercel serverless.
DATABASE_PATH=./ara.db

# Optional: GitHub token for config fetch rate limits
# GITHUB_TOKEN=

# Dashboard widgets (server-side keys; app calls your Vercel API)
# NewsAPI: https://newsapi.org/register
NEWS_API_KEY=
# Alpha Vantage: https://www.alphavantage.co/support/#api-key (stocks: CFG, NASDAQ, S&P 500)
ALPHA_VANTAGE_KEY=
# Unsplash: https://unsplash.com/developers (elegant shoes widget)
UNSPLASH_ACCESS_KEY=

# Sonos local control (speakers configured in app settings via localStorage)
# No server-side config needed — tablet talks directly to speakers.

# Spotify (for voice-controlled music on Sonos)
# Create app: https://developer.spotify.com/dashboard
# Redirect URI: https://your-vercel-url/api/spotify/callback/
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube Data API (optional — falls back to search URL without it)
# Get key: https://console.cloud.google.com/apis/credentials
# YOUTUBE_API_KEY=

# Feature flags (default true when unset)
# ENABLE_LEARNING=true
# ENABLE_CLAUDE_FOR_TASKS=true
# ENABLE_GROK_FOR_CHAT=true
